#include <iostream>
using namespace std;
int MajorCode;
string MajorName, QuotaStatus;
void Input()
{
	cout << "=== Campus Major Registration ===\n";
	cout << "1. Information Technology\n";
	cout << "2. Electrical Engineering\n";
	cout << "3. Information Systems\n\n";

	cout << "----------------------------------------------------------\n";
	cout << "Enter Major Code (1-3) :  "; cin >> MajorCode;
}
void SelectMajor()
{

	switch (MajorCode)
	{

	case 1:
		MajorName = "Information Technology";
		QuotaStatus = "Available 15 seats";
		break;

	case 2:
		MajorName = "Electrical Engineering";
		QuotaStatus = "Quota Full";
		break;
	case 3:
		MajorName = "Information Systems";
		QuotaStatus = "Available 5 seats";
		break;

	default :
		MajorName = "No Major";
		QuotaStatus = "Error : The Code is not Valid";
		break;

	}


}
void Output()
{

	cout << "\n===Seelction Result===\n";
	cout << "Major Name : " << MajorName << endl;
	cout << "Seats Status :" << QuotaStatus << endl;
	cout << "-----------------------------------------------";
}
int main()
{
Input();
SelectMajor();
Output();
return 0;

}
